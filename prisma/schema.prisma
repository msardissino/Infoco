generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  excerpt   String
  content   String
  status    String   @default("Borrador")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Edition {
  id        Int      @id @default(autoincrement())
  title     String
  pdfUrl    String
  status    String   @default("Borrador")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
